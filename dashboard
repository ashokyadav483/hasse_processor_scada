client = st.session_state.plc_client

# Safe read function with error handling
def read_node(node_id, default=0):
    try:
        node = client.get_node(node_id)
        return node.get_value()
    except:
        return default

# Safe write function
def write_bool(node_id, value):
    try:
        node = client.get_node(node_id)
        node.set_value(ua.DataValue(ua.Variant(value, ua.VariantType.Boolean)))
        return True
    except Exception as e:
        st.error(f"Write Error: {e}")
        return False

