performance = min(performance, 100)
quality = 100  # Update with actual quality data when available

oee = (availability/100) * (performance/100) * (quality/100) * 100

oee_col1, oee_col2, oee_col3, oee_col4 = st.columns(4)

with oee_col1:
    st.markdown('<div class="metric-card">', unsafe_allow_html=True)
    st.metric("📊 Availability", f"{availability:.1f}%", 
              delta="Good" if availability > 90 else "Poor",
              delta_color="normal")
    st.progress(availability/100)
    st.caption("Machine uptime performance")
    st.markdown('</div>', unsafe_allow_html=True)

with oee_col2:
    st.markdown('<div class="metric-card">', unsafe_allow_html=True)
    st.metric("⚡ Performance", f"{performance:.1f}%",
              delta="Good" if performance > 85 else "Poor",
              delta_color="normal")
    st.progress(performance/100)
    st.caption("Speed efficiency")
    st.markdown('</div>', unsafe_allow_html=True)

with oee_col3:
    st.markdown('<div class="metric-card">', unsafe_allow_html=True)
    st.metric("✅ Quality", f"{quality:.1f}%",
              delta="Excellent", delta_color="normal")
    st.progress(quality/100)
    st.caption("First pass yield")
    st.markdown('</div>', unsafe_allow_html=True)

with oee_col4:
    st.markdown('<div class="metric-card">', unsafe_allow_html=True)
    # Color code OEE based on value
    if oee >= 85:
        oee_color = "success-text"
        oee_rating = "🏆 WORLD CLASS"
    elif oee >= 60:
        oee_color = "warning-text"
        oee_rating = "⚠️ NEEDS IMPROVEMENT"
    else:
        oee_color = "danger-text"
        oee_rating = "🔴 CRITICAL"
    
    st.markdown(f'<div class="{oee_color}">', unsafe_allow_html=True)
    st.metric("🎯 Overall OEE", f"{oee:.1f}%")
    st.markdown('</div>', unsafe_allow_html=True)
    st.progress(oee/100)
    st.caption(oee_rating)
    st.markdown('</div>', unsafe_allow_html=True)

# Alerts and Notifications
st.markdown("### ⚠️ ALERTS & NOTIFICATIONS")
alert_container = st.container()

with alert_container:
    alerts = []
    
    # Temperature alerts
    if values['PREHEAT_LEFT_TEMP'] > 180:
        alerts.append(("🔴 CRITICAL: Left Preheat temperature exceeding limit! (Current: {:.1f}°C)".format(values['PREHEAT_LEFT_TEMP']), "critical"))
    elif values['PREHEAT_LEFT_TEMP'] > 160:
        alerts.append(("⚠️ WARNING: Left Preheat temperature high (Current: {:.1f}°C)".format(values['PREHEAT_LEFT_TEMP']), "warning"))
    
    if values['PREHEAT_FAN_TEMP'] > 180:
        alerts.append(("🔴 CRITICAL: Fan Preheat temperature exceeding limit! (Current: {:.1f}°C)".format(values['PREHEAT_FAN_TEMP']), "critical"))
    elif values['PREHEAT_FAN_TEMP'] > 160:
        alerts.append(("⚠️ WARNING: Fan Preheat temperature high (Current: {:.1f}°C)".format(values['PREHEAT_FAN_TEMP']), "warning"))
    
    if values['DEVELOPER_TEMP'] > 45:
        alerts.append(("🔴 CRITICAL: Developer temperature too high! (Current: {:.1f}°C)".format(values['DEVELOPER_TEMP']), "critical"))
    elif values['DEVELOPER_TEMP'] > 40:
        alerts.append(("⚠️ WARNING: Developer temperature high (Current: {:.1f}°C)".format(values['DEVELOPER_TEMP']), "warning"))
    
    # Production alerts
    if not values["MACHINE_START"]:
        alerts.append(("⏹️ MACHINE STOPPED - Production halted", "warning"))
    
    if alerts:
        for alert, level in alerts:
            if level == "critical":
                st.markdown(f'<div class="alert-box alert-critical">{alert}</div>', unsafe_allow_html=True)
            else:
                st.markdown(f'<div class="alert-box alert-warning">{alert}</div>', unsafe_allow_html=True)
    else:
        st.markdown('<div class="alert-box alert-success">✅ All systems operating normally</div>', unsafe_allow_html=True)

