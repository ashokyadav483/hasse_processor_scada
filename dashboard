def get_temp_status(temp, warning=160, critical=180):
    if temp >= critical:
        return "🔴 CRITICAL", "danger-text"
    elif temp >= warning:
        return "⚠️ WARNING", "warning-text"
    else:
        return "✅ NORMAL", "success-text"

